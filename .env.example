# Скопіюй цей файл у .env для локального запуску (на Render ці значення
# задаються в розділі Environment, не через файл).

# Gmail-акаунт, з якого будуть надсилатись листи з кодами
GMAIL_USER=shevchenko.myrosia@gmail.com

# App Password з Google-акаунту (НЕ звичайний пароль від пошти!)
# Як отримати: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
